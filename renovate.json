{
  "extends": ["config:recommended"],
  "ignorePaths": [".github/workflows/**"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/template\\.ya?ml$/"],
      "matchStrings": [
        "SemanticVersion:\\s*(?<currentValue>[0-9.]+)"
      ],
      "autoReplaceStringTemplate": "SemanticVersion: {{newVersion}}",
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "surajkumar/gds-spike-releases-example"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["surajkumar/gds-spike-releases-example"],
      "versioning": "semver"
    }
  ]
}
